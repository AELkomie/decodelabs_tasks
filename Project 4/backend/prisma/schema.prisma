generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Intern {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String   @default("Intern")
  skills    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("interns")
}
